from IPython.display import Audio, display, Javascript
from google.colab import output
from base64 import b64decode

RECORD = """
const sleep = time => new Promise(resolve => setTimeout(resolve, time))

const b2text = blob => new Promise(resolve => {
  const reader = new FileReader()
  reader.onloadend = () => resolve(reader.result)
  reader.readAsDataURL(blob)
})

var record = async (time) => {
  // Cria o botão visualmente
  const div = document.createElement('div');
  const btn = document.createElement('button');
  btn.textContent = 'Clique para Falar';
  btn.style.background = '#ff4b4b';
  btn.style.color = 'white';
  btn.style.border = 'none';
  btn.style.padding = '10px 20px';
  btn.style.borderRadius = '5px';
  btn.style.cursor = 'pointer';
  btn.style.marginBottom = '10px';

  div.appendChild(btn);
  document.body.appendChild(div);

  // Espera o clique do usuário para começar de fato
  await new Promise(resolve => btn.onclick = resolve);

  btn.textContent = 'Gravando...';
  btn.style.background = '#28a745';

  const stream = await navigator.mediaDevices.getUserMedia({ audio: true })
  const recorder = new MediaRecorder(stream)
  const chunks = []

  recorder.ondataavailable = e => chunks.push(e.data)
  recorder.start()

  await sleep(time)

  const data = await new Promise(resolve => {
    recorder.onstop = async () => {
      let blob = new Blob(chunks)
      let text = await b2text(blob)
      resolve(text)
    }
    recorder.stop()
  })

  stream.getTracks().forEach(track => track.stop()); // Desliga o microfone
  div.remove(); // Remove o botão da tela
  return data;
}
"""


def record(sec=5):
  display(Javascript(RECORD))
  js_result = output.eval_js('record(%s)' % (sec * 1000))
  audio = b64decode(js_result.split(',')[1])
  file_name = 'request_audio.wav'
  with open(file_name, 'wb') as f:
    f.write(audio)
  return f'/content/{file_name}'

print('Sou seu agente de nutrição. Meu papel é auxiliar você a transformar sua alimentação em uma ferramenta de vitalidade e prevenção de doenças.')
record_file = record()
display(Audio(record_file, autoplay=False))

